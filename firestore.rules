rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 【重要】一時的に全開放（シードデータ投入のため）
    match /menus/{menuId} {
      allow read, write: if true;
    }
    
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // 他の全てのパスもデバッグ用に一時許可
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
